# Copia este archivo como .env y completa los valores
# cp .env.example .env

# Servidor
PORT=3001

# Base de datos PostgreSQL
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kiora
DATABASE_URL=postgres://USER:PASSWORD@kiora-db:5432/kiora

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Redis (blacklist de tokens JWT)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=          # Descomentar si Redis tiene contraseña

# Email (Resend) — HU05: Recuperación de contraseña
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=no-reply@tudominio.com
APP_URL=http://localhost:3000   # URL base del frontend (para el link del email)

# CORS
CORS_ORIGIN=http://localhost:3000

# Entorno
NODE_ENV=development
